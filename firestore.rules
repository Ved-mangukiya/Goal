// Use this file with the current app (no sign-in).
// For rules that require login, see firestore.rules.require-auth.example instead.
// Never paste two rule sets into one file.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
